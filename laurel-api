#!/usr/bin/env python3
"""laurel-api — lightweight clip management API for Laurel.

Endpoints:
    POST /api/register         — register an ident (open registration)
    POST /api/upload           — upload a clip (multipart: file + ident + html)
    GET  /api/clips            — list clips owned by ident (from cookie or header)
    PATCH /api/clips/<slug>    — rename a clip (JSON body: {"name": "..."})
    DELETE /api/clips/<slug>   — delete a clip

Reads .owner files from /srv/clips/<slug>/ to determine ownership.
No database — the filesystem is the source of truth.
"""

import http.server
import json
import os
import re
import shutil
import subprocess
import sys
import tempfile
from email.parser import BytesParser
from http.cookies import SimpleCookie
from io import BytesIO
from urllib.parse import urlparse, parse_qs

CLIP_DIR = os.environ.get("CLIP_DIR", "/srv/clips")
BIND = os.environ.get("API_BIND", os.environ.get("BIND", "127.0.0.1"))
PORT = int(os.environ.get("API_PORT", os.environ.get("PORT", "9100")))

# Max upload size: 500MB
MAX_UPLOAD = 500 * 1024 * 1024

SLUG_RE = re.compile(r"^[0-9]{8}-[0-9]{6}-[0-9a-f]{8}$")
IDENT_RE = re.compile(r"^[0-9a-f]{32}$")

# Registered idents stored in a simple file (one per line)
IDENTS_FILE = os.path.join(CLIP_DIR, ".idents")


def load_idents():
    """Load registered idents from file."""
    if not os.path.isfile(IDENTS_FILE):
        return set()
    with open(IDENTS_FILE) as f:
        return {line.strip() for line in f if line.strip()}


def save_ident(ident):
    """Append a new ident to the registry."""
    with open(IDENTS_FILE, "a") as f:
        f.write(ident + "\n")


def is_registered(ident):
    """Check if ident is registered OR has any clips (backward compat)."""
    if ident in load_idents():
        return True
    # Backward compat: if they already have clips with .owner files, they're legit
    if os.path.isdir(CLIP_DIR):
        for entry in os.listdir(CLIP_DIR):
            owner_file = os.path.join(CLIP_DIR, entry, ".owner")
            if os.path.isfile(owner_file):
                with open(owner_file) as f:
                    if f.read().strip() == ident:
                        return True
    return False


def get_ident(headers):
    """Extract ident from X-Ident header or cookie."""
    # Prefer header (for API clients like laurel-clip)
    ident = headers.get("X-Ident", "")
    if ident and IDENT_RE.match(ident):
        return ident
    # Fall back to cookie (for browser UI)
    cookie_header = headers.get("Cookie", "")
    cookie = SimpleCookie()
    cookie.load(cookie_header)
    if "ident" in cookie:
        return cookie["ident"].value
    return None


def list_clips(ident):
    """List all clips owned by ident."""
    clips = []
    if not os.path.isdir(CLIP_DIR):
        return clips
    for entry in sorted(os.listdir(CLIP_DIR), reverse=True):
        slug_dir = os.path.join(CLIP_DIR, entry)
        if not os.path.isdir(slug_dir) or not SLUG_RE.match(entry):
            continue
        owner_file = os.path.join(slug_dir, ".owner")
        if not os.path.isfile(owner_file):
            continue
        with open(owner_file) as f:
            owner = f.read().strip()
        if owner != ident:
            continue
        # Read optional display name
        name_file = os.path.join(slug_dir, ".name")
        name = ""
        if os.path.isfile(name_file):
            with open(name_file) as f:
                name = f.read().strip()
        # Find the video file
        video = ""
        for fname in os.listdir(slug_dir):
            if fname.endswith(".mp4"):
                video = fname
                break
        # Get thumb existence and file size
        thumb = os.path.isfile(os.path.join(slug_dir, "thumb.jpg"))
        size = 0
        if video:
            try:
                size = os.path.getsize(os.path.join(slug_dir, video))
            except OSError:
                pass

        clips.append({
            "slug": entry,
            "name": name,
            "video": video,
            "thumb": thumb,
            "size": size,
        })
    return clips


def _parse_multipart(body, boundary):
    """Parse multipart form data. Returns dict of {name: (data, filename)}."""
    parts = {}
    delimiter = b"--" + boundary
    chunks = body.split(delimiter)
    for chunk in chunks:
        # Skip preamble and closing
        if not chunk or chunk.strip() == b"--" or chunk.strip() == b"":
            continue
        # Split headers from body (separated by \r\n\r\n)
        if b"\r\n\r\n" not in chunk:
            continue
        header_block, data = chunk.split(b"\r\n\r\n", 1)
        # Remove trailing \r\n from data
        if data.endswith(b"\r\n"):
            data = data[:-2]
        # Parse Content-Disposition
        name = None
        filename = None
        for line in header_block.decode("utf-8", errors="replace").split("\r\n"):
            if "Content-Disposition:" in line:
                for param in line.split(";"):
                    param = param.strip()
                    if param.startswith("name="):
                        name = param[5:].strip('"')
                    elif param.startswith("filename="):
                        filename = param[9:].strip('"')
        if name:
            parts[name] = (data, filename)
    return parts


class Handler(http.server.BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        # Quiet logging — systemd journal captures stderr
        pass

    def send_json(self, code, data):
        body = json.dumps(data).encode()
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", len(body))
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self):
        parsed = urlparse(self.path)
        if parsed.path != "/api/clips":
            self.send_json(404, {"error": "not found"})
            return
        ident = get_ident(self.headers)
        if not ident:
            self.send_json(401, {"error": "no ident"})
            return
        clips = list_clips(ident)
        self.send_json(200, {"clips": clips})

    def do_POST(self):
        parsed = urlparse(self.path)

        if parsed.path == "/api/register":
            self._handle_register()
        elif parsed.path == "/api/upload":
            self._handle_upload()
        else:
            self.send_json(404, {"error": "not found"})

    def _handle_register(self):
        """Register a new ident. Open registration."""
        length = int(self.headers.get("Content-Length", 0))
        body = self.rfile.read(length) if length else b""
        try:
            data = json.loads(body)
        except (json.JSONDecodeError, ValueError):
            self.send_json(400, {"error": "invalid JSON"})
            return

        ident = data.get("ident", "").strip()
        if not ident or not IDENT_RE.match(ident):
            self.send_json(400, {"error": "invalid ident (must be 32 hex chars)"})
            return

        if is_registered(ident):
            # Already registered — that's fine, just confirm
            self.send_json(200, {"status": "ok", "message": "already registered"})
            return

        save_ident(ident)
        print(f"registered new ident: {ident[:8]}...", file=sys.stderr)
        self.send_json(201, {"status": "ok", "message": "registered"})

    def _handle_upload(self):
        """Handle clip upload via multipart form data."""
        ident = get_ident(self.headers)
        if not ident:
            self.send_json(401, {"error": "no ident"})
            return

        if not is_registered(ident):
            self.send_json(403, {"error": "ident not registered"})
            return

        # Check content length
        content_length = int(self.headers.get("Content-Length", 0))
        if content_length > MAX_UPLOAD:
            self.send_json(413, {"error": "file too large (max 500MB)"})
            return

        # Parse multipart form
        content_type = self.headers.get("Content-Type", "")
        if "multipart/form-data" not in content_type:
            self.send_json(400, {"error": "expected multipart/form-data"})
            return

        # Extract boundary
        boundary = None
        for part in content_type.split(";"):
            part = part.strip()
            if part.startswith("boundary="):
                boundary = part[9:].strip('"')
        if not boundary:
            self.send_json(400, {"error": "no boundary in content-type"})
            return

        # Read the full body
        body = self.rfile.read(content_length)

        # Parse multipart manually
        parts = _parse_multipart(body, boundary.encode())

        if "file" not in parts:
            self.send_json(400, {"error": "missing 'file' field"})
            return

        file_data, file_filename = parts["file"]
        if not file_filename:
            self.send_json(400, {"error": "no filename"})
            return

        slug_data = parts.get("slug", (b"", None))
        slug = slug_data[0].decode().strip() if slug_data[0] else ""
        if not slug or not SLUG_RE.match(slug):
            self.send_json(400, {"error": "invalid slug"})
            return

        html_data = parts.get("html", (b"", None))
        html_content = html_data[0].decode() if html_data[0] else ""

        # Create clip directory
        clip_dir = os.path.join(CLIP_DIR, slug)
        if os.path.exists(clip_dir):
            self.send_json(409, {"error": "slug already exists"})
            return

        os.makedirs(clip_dir, mode=0o755)

        # Save video file
        filename = os.path.basename(file_filename)
        video_path = os.path.join(clip_dir, filename)
        with open(video_path, "wb") as f:
            f.write(file_data)
        os.chmod(video_path, 0o644)

        # Save HTML page
        if html_content:
            html_path = os.path.join(clip_dir, "index.html")
            with open(html_path, "w") as f:
                f.write(html_content)
            os.chmod(html_path, 0o644)

        # Save owner
        owner_path = os.path.join(clip_dir, ".owner")
        with open(owner_path, "w") as f:
            f.write(ident)

        # Generate thumbnail (first frame)
        thumb_path = os.path.join(clip_dir, "thumb.jpg")
        try:
            subprocess.run(
                ["ffmpeg", "-y", "-i", video_path, "-vframes", "1",
                 "-q:v", "2", thumb_path],
                capture_output=True, timeout=30,
            )
        except Exception:
            pass  # Thumbnail is optional

        domain = os.environ.get("DOMAIN", "")
        url = f"https://{domain}/{slug}" if domain else f"/{slug}"

        print(f"upload: {slug} by {ident[:8]}... ({content_length} bytes)", file=sys.stderr)
        self.send_json(201, {"status": "ok", "slug": slug, "url": url})

    def do_PATCH(self):
        parsed = urlparse(self.path)
        m = re.match(r"^/api/clips/([0-9]{8}-[0-9]{6}-[0-9a-f]{8})$", parsed.path)
        if not m:
            self.send_json(404, {"error": "not found"})
            return
        slug = m.group(1)
        ident = get_ident(self.headers)
        if not ident:
            self.send_json(401, {"error": "no ident"})
            return
        # Check ownership
        owner_file = os.path.join(CLIP_DIR, slug, ".owner")
        if not os.path.isfile(owner_file):
            self.send_json(404, {"error": "clip not found"})
            return
        with open(owner_file) as f:
            owner = f.read().strip()
        if owner != ident:
            self.send_json(403, {"error": "not your clip"})
            return
        # Read body
        length = int(self.headers.get("Content-Length", 0))
        body = self.rfile.read(length) if length else b""
        try:
            data = json.loads(body)
        except (json.JSONDecodeError, ValueError):
            self.send_json(400, {"error": "invalid JSON"})
            return
        name = data.get("name", "").strip()
        if not name:
            self.send_json(400, {"error": "name required"})
            return
        # Write display name
        name_file = os.path.join(CLIP_DIR, slug, ".name")
        with open(name_file, "w") as f:
            f.write(name)
        self.send_json(200, {"slug": slug, "name": name})

    def do_DELETE(self):
        parsed = urlparse(self.path)
        m = re.match(r"^/api/clips/([0-9]{8}-[0-9]{6}-[0-9a-f]{8})$", parsed.path)
        if not m:
            self.send_json(404, {"error": "not found"})
            return
        slug = m.group(1)
        ident = get_ident(self.headers)
        if not ident:
            self.send_json(401, {"error": "no ident"})
            return
        # Check ownership
        clip_dir = os.path.join(CLIP_DIR, slug)
        owner_file = os.path.join(clip_dir, ".owner")
        if not os.path.isfile(owner_file):
            self.send_json(404, {"error": "clip not found"})
            return
        with open(owner_file) as f:
            owner = f.read().strip()
        if owner != ident:
            self.send_json(403, {"error": "not your clip"})
            return
        # Delete
        shutil.rmtree(clip_dir)
        self.send_json(200, {"deleted": slug})


if __name__ == "__main__":
    server = http.server.HTTPServer((BIND, PORT), Handler)
    print(f"laurel-api listening on {BIND}:{PORT}", file=sys.stderr)
    server.serve_forever()
