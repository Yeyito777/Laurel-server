#!/bin/sh
# Laurel server auto-deploy hook
# Install: cp post-receive ~/laurel-server.git/hooks/ && chmod +x ~/laurel-server.git/hooks/post-receive

DEPLOY_DIR=/opt/laurel-server
CONF_FILE=/etc/laurel-server.conf

echo "==> Deploying Laurel server..."

# Load config
if [ ! -f "$CONF_FILE" ]; then
    echo "    ERROR: $CONF_FILE not found."
    echo "    Copy laurel-server.conf.example to $CONF_FILE and edit it."
    exit 1
fi
. "$CONF_FILE"

# Validate required config
if [ -z "$DOMAIN" ] || [ "$DOMAIN" = "clips.example.com" ]; then
    echo "    ERROR: DOMAIN not set in $CONF_FILE"
    exit 1
fi
if [ -z "$USER" ] || [ "$USER" = "laurel" ]; then
    echo "    WARNING: USER is default 'laurel' — make sure this user exists"
fi

# Defaults
CLIP_DIR="${CLIP_DIR:-/srv/clips}"
API_BIND="${API_BIND:-127.0.0.1}"
API_PORT="${API_PORT:-9100}"

# Checkout latest code
mkdir -p "$DEPLOY_DIR"
GIT_WORK_TREE="$DEPLOY_DIR" git checkout -f main 2>/dev/null || \
GIT_WORK_TREE="$DEPLOY_DIR" git checkout -f master
echo "    Checked out to $DEPLOY_DIR"

# Template helper: replace {{VAR}} placeholders
template() {
    sed -e "s|{{DOMAIN}}|${DOMAIN}|g" \
        -e "s|{{USER}}|${USER}|g" \
        -e "s|{{CLIP_DIR}}|${CLIP_DIR}|g" \
        -e "s|{{API_BIND}}|${API_BIND}|g" \
        -e "s|{{API_PORT}}|${API_PORT}|g" \
        "$1"
}

# Deploy homepage
if [ -f "$DEPLOY_DIR/index.html" ]; then
    cp "$DEPLOY_DIR/index.html" "$CLIP_DIR/index.html"
    chmod 644 "$CLIP_DIR/index.html"
    echo "    Deployed homepage"
fi

# Deploy nginx config (templated)
NGINX_DST="/etc/nginx/sites-available/$DOMAIN"
NGINX_TMP="$(mktemp)"
template "$DEPLOY_DIR/laurel.nginx.conf" > "$NGINX_TMP"
if ! diff -q "$NGINX_TMP" "$NGINX_DST" >/dev/null 2>&1; then
    sudo cp "$NGINX_TMP" "$NGINX_DST"
    # Ensure symlink exists
    sudo ln -sf "$NGINX_DST" "/etc/nginx/sites-enabled/$DOMAIN"
    if sudo nginx -t 2>&1; then
        sudo systemctl reload nginx
        echo "    Nginx config updated and reloaded"
    else
        echo "    ERROR: nginx config test failed, not reloading"
    fi
else
    echo "    Nginx config unchanged"
fi
rm -f "$NGINX_TMP"

# Deploy API service
if [ -f "$DEPLOY_DIR/laurel-api" ]; then
    chmod +x "$DEPLOY_DIR/laurel-api"
    # Write a service file pointing to the git-deployed binary
    cat > /tmp/laurel-api.service << SVCEOF
[Unit]
Description=Laurel clip management API
After=network.target

[Service]
Type=simple
ExecStart=${DEPLOY_DIR}/laurel-api
EnvironmentFile=/etc/laurel-server.conf
User=${USER}
ReadWritePaths=${CLIP_DIR}
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
SVCEOF
    sudo cp /tmp/laurel-api.service /etc/systemd/system/laurel-api.service
    rm -f /tmp/laurel-api.service
    sudo systemctl daemon-reload
    sudo systemctl enable --now laurel-api
    sudo systemctl restart laurel-api
    echo "    API service deployed and restarted"
fi

echo "==> Deploy complete ($DOMAIN)"
